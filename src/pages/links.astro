---
import Base from '../layouts/Base.astro';

const links = [
  { name: 'GitHub', url: 'github.com/gl-tches', href: 'https://github.com/gl-tches' },
  { name: 'Uptime', url: 'status.gl-tches.com', href: 'https://status.gl-tches.com' },
];
---

<Base title="Links" currentPage="links">
  <div class="page-header">
    <h1>LINKS</h1>
    <p class="subtitle">Elsewhere on the internet.</p>
  </div>

  <div class="post-list">
    {links.map((link) => (
      <a href={link.href} target="_blank" rel="noopener" class="link-item">
        <span class="link-name">{link.name}</span>
        <span class="link-url">{link.url}</span>
      </a>
    ))}
  </div>
</Base>
