---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const active = projects.filter(p => p.data.status === 'active');
const wip = projects.filter(p => p.data.status === 'wip');
const archived = projects.filter(p => p.data.status === 'archived');
---

<Base title="Projects" currentPage="projects">
  <div class="page-header">
    <h1>PROJECTS</h1>
    <p class="subtitle">Things I'm building, breaking, or have broken.</p>
  </div>

  {active.length > 0 && (
    <section>
      <h2>ACTIVE</h2>
      <div class="card-grid card-grid--2col">
        {active.map((project) => (
          <div class="card">
            <a href={project.data.url || project.data.repo || '#'} target="_blank" rel="noopener">
              <div class="card-title">{project.data.title}</div>
              <p class="card-excerpt">{project.data.description}</p>
              {project.data.tags && (
                <div class="tags">
                  {project.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              {project.data.repo && (
                <div class="card-meta">{project.data.repo}</div>
              )}
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  {wip.length > 0 && (
    <section>
      <h2>WORK IN PROGRESS</h2>
      <div class="card-grid card-grid--2col">
        {wip.map((project) => (
          <div class="card">
            <a href={project.data.url || project.data.repo || '#'} target="_blank" rel="noopener">
              <div class="card-title">{project.data.title}</div>
              <p class="card-excerpt">{project.data.description}</p>
              {project.data.tags && (
                <div class="tags">
                  {project.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  {archived.length > 0 && (
    <section>
      <h2>ARCHIVED</h2>
      <div class="card-grid card-grid--2col">
        {archived.map((project) => (
          <div class="card">
            <div class="card-title">{project.data.title}</div>
            <p class="card-excerpt">{project.data.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}
</Base>

<style>
  section {
    margin-bottom: 3rem;
  }

  section h2 {
    margin-bottom: 1.25rem;
  }
</style>
